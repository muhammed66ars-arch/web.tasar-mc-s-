  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{

      background:black;

      color:white;

      font-family:'Poppins',sans-serif;
    }

    /* ÜST MENÜ */

    nav{

      display:flex;

      justify-content:space-between;

      align-items:center;

      padding:25px 10%;

      background:#111;

      border-bottom:1px solid #222;
    }

    nav h2{
      color:orange;
      font-size:30px;
    }

    nav ul{
      display:flex;
      gap:25px;
      list-style:none;
    }

    nav a{
      color:white;
      text-decoration:none;
      transition:0.3s;
    }

    nav a:hover{
      color:orange;
    }

    /* ANA ALAN */

    .hero{

      height:90vh;

      display:flex;

      justify-content:center;

      align-items:center;

      gap:80px;

      padding:0 10%;

      flex-wrap:wrap;
    }

    /* YAZI ALANI */

    .text{
      max-width:500px;
    }

    .text h1{

      font-size:60px;

      margin-bottom:20px;
    }

    .text h1 span{
      color:orange;
    }

    .text h3{

      font-size:25px;

      color:#aaa;

      margin-bottom:20px;
    }

    .text p{

      line-height:1.8;

      color:#d0d0d0;

      margin-bottom:30px;
    }

    /* BUTONLAR */

    .buttons{
      display:flex;
      gap:20px;
      flex-wrap:wrap;
    }

    button{

      padding:14px 30px;

      border:none;

      border-radius:12px;

      background:orange;

      color:black;

      font-size:16px;

      font-weight:bold;

      cursor:pointer;

      transition:0.3s;
    }

    button:hover{

      transform:scale(1.1);

      background:white;
    }

    /* FOTOĞRAF */

    .image img{

      width:320px;

      height:320px;

      object-fit:cover;

      border-radius:50%;

      border:5px solid orange;

      box-shadow:0 0 40px orange;
    }

    /* İLETİŞİM */

    .contact{

      text-align:center;

      padding:80px 20px;

      background:#111;
    }

    .contact h2{

      font-size:40px;

      margin-bottom:20px;

      color:orange;
    }

    .contact p{

      margin:10px 0;

      color:#ccc;
    }

  </style>
</head>
<body>

